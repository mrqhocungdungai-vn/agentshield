agentshield:
  enabled: true

  # Không có owner qua Telegram — chủ nhân dùng CLI trực tiếp trên máy
  # owner_chat_id: disabled

  # Tất cả user qua Telegram đều là guest — không có phân biệt role
  deny_unlisted: false

  roles:
    guest:
      chat_ids: []
      allow: ["chat"]
      deny: ["command:*", "system:*", "terminal", "skill:*"]
      rate_limit:
        messages_per_minute: 10
        messages_per_day: 200

  alerts:
    on_action_denied: false   # không có owner Telegram để nhận alert
    on_rate_limit: false

  messages:
    rate_limit_minute: "Mình đang xử lý khá nhiều tin nhắn cùng lúc, bạn vui lòng chờ một chút rồi nhắn lại nhé 😊"
    rate_limit_day: "Hôm nay mình đã hỗ trợ bạn khá nhiều rồi. Bạn có thể tiếp tục trò chuyện vào ngày mai, hoặc liên hệ trực tiếp với đội ngũ hỗ trợ của chúng tôi nhé!"
    action_denied: "Tính năng này hiện không khả dụng trong kênh chat. Bạn cần hỗ trợ thêm, vui lòng liên hệ trực tiếp với nhân viên của chúng tôi nhé 😊"
    unlisted_denied: "Xin chào! Kênh hỗ trợ này hiện đang trong giai đoạn thử nghiệm. Vui lòng liên hệ chúng tôi qua các kênh chính thức để được hỗ trợ."
