agentshield:
  enabled: true

  # Không có owner qua Telegram — chủ nhân dùng CLI trực tiếp trên máy
  # owner_chat_id: disabled

  # Tất cả user qua Telegram đều là guest — không có phân biệt role
  deny_unlisted: false

  roles:
    guest:
      chat_ids: []
      allow: ["chat"]
      deny: ["command:*", "system:*", "terminal", "skill:*"]
      rate_limit:
        messages_per_minute: 10
        messages_per_day: 200

  alerts:
    on_action_denied: false   # không có owner Telegram để nhận alert
    on_rate_limit: false

  messages:
    rate_limit_minute: "I'm handling a lot of messages right now — please try again in a moment 😊"
    rate_limit_day: "You've reached today's message limit. Feel free to continue tomorrow, or contact our support team directly!"
    action_denied: "That feature isn't available in this chat. Please contact our support team for further assistance 😊"
    unlisted_denied: "Hello! This support channel is currently in beta. Please reach out through our official channels."
