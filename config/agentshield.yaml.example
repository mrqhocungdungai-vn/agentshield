agentshield:
  enabled: true

  # Rate limits applied equally to ALL users — there is only one role.
  # Edit these values with: agentshield-config
  rate_limit:
    messages_per_minute: 10
    messages_per_day: 200

  # Actions allowed for all users
  allow:
    - "chat"

  # Actions blocked for all users
  # Wildcard patterns supported (fnmatch syntax)
  deny:
    - "command:*"   # all slash commands
    - "skill:*"     # skill invocations
    - "system:*"    # /reset, /new, /stop, etc.
    - "terminal"    # terminal tool

  # Response messages shown to users when blocked
  messages:
    rate_limit_minute: "Tôi đang xử lý nhiều yêu cầu — bạn vui lòng thử lại sau giây lát nhé 😊"
    rate_limit_day: "Bạn đã đạt giới hạn tin nhắn hôm nay. Hẹn gặp lại bạn vào ngày mai!"
    action_denied: "Tính năng này chưa khả dụng trong cuộc trò chuyện này. Vui lòng liên hệ bộ phận hỗ trợ 😊"

  # Conversation logging
  logging:
    conversations: true                  # log every turn to ~/.hermes/logs/conversations/
    max_bytes_per_user: 10485760         # 10 MB soft cap per user log (oldest lines dropped)

  # Owner alert — optional. Set TELEGRAM_BOT_TOKEN env var to enable.
  # owner_chat_id: "YOUR_TELEGRAM_CHAT_ID"
